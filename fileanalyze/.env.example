# -----------------------------
# App/runtime
# -----------------------------
APP_ENV=production
APP_BASE_URL=https://example.com
SESSION_SECRET=replace_with_long_random_secret

# -----------------------------
# File Analyze framework
# -----------------------------
FILEANALYZE_HOST=0.0.0.0
FILEANALYZE_PORT=8050
FILEANALYZE_DEBUG=false
FILEANALYZE_OUTPUT_ROOT=./fileanalyze/output
FILEANALYZE_STATE_ROOT=./fileanalyze/state
FILEANALYZE_CACHE_ROOT=./fileanalyze/cache
FILEANALYZE_TEMP_ROOT=./fileanalyze/tmp
FILEANALYZE_MAX_UPLOAD_MB=512
FILEANALYZE_WORKER_COUNT=4
FILEANALYZE_LOG_LEVEL=INFO
FILEANALYZE_PROFILE_TOPN=25
FILEANALYZE_MAX_PREVIEW_ROWS=5000
FILEANALYZE_ENABLE_ENV_OVERRIDE=false
FILEANALYZE_SESSION_TTL_HOURS=12
FILEANALYZE_RUN_TTL_HOURS=24
FILEANALYZE_RETENTION_SWEEP_MINUTES=15
